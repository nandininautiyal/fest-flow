<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'FestFlow Admin' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --midnight: #0D0E1A;
      --navy: #13152A;
      --smoke: #4A4560;
      --gold: #C9A84C;
      --gold-dim: #8A6F2E;
      --crimson: #8B1A1A;
      --parchment: #F0E6C8;
      --parchment-dim: #A89878;
      --white: #FDFAF3;
      --font-display: 'Cinzel', serif;
      --font-body: 'EB Garamond', serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--midnight);
      color: var(--parchment);
      font-family: var(--font-body);
      font-size: 1.05rem;
      line-height: 1.6;
      min-height: 100vh;
    }
    h1, h2, h3 { font-family: var(--font-display); color: var(--white); letter-spacing: 0.04em; }
    a { color: var(--gold); text-decoration: none; }
    .topbar {
      display: flex; justify-content: space-between; align-items: center;
      padding: 1rem 2rem; border-bottom: 1px solid rgba(201,168,76,0.2);
      background: rgba(13,14,26,0.9);
    }
    .brand { font-family: var(--font-display); color: var(--gold); letter-spacing: 0.15em; font-size: 1.1rem; text-transform: uppercase; }
    .topnav { display: flex; gap: 1.5rem; }
    .topnav a { font-family: var(--font-display); font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--parchment-dim); }
    .topnav a:hover { color: var(--gold); }
    .wrap { max-width: 1000px; margin: 0 auto; padding: 2.5rem 2rem; }
    .card {
      background: var(--navy); border: 1px solid rgba(201,168,76,0.15);
      border-radius: 2px; padding: 1.5rem; margin-bottom: 1rem;
    }
    .btn {
      font-family: var(--font-display); font-size: 0.75rem; letter-spacing: 0.12em;
      text-transform: uppercase; padding: 0.7rem 1.6rem; border: 1px solid var(--gold);
      background: transparent; color: var(--gold); border-radius: 2px; cursor: pointer;
    }
    .btn:hover { background: var(--gold); color: var(--midnight); }
    .btn-solid { background: var(--gold); color: var(--midnight); }
    .form-group { margin-bottom: 1.1rem; display: flex; flex-direction: column; gap: 0.35rem; }
    .form-group label { font-family: var(--font-display); font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--parchment-dim); }
    .form-group input, .form-group select, .form-group textarea {
      background: var(--midnight); border: 1px solid var(--smoke); color: var(--parchment);
      padding: 0.65rem 0.9rem; font-family: var(--font-body); font-size: 1rem; border-radius: 2px;
    }
    table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
    th, td { text-align: left; padding: 0.6rem 0.8rem; border-bottom: 1px solid rgba(201,168,76,0.1); font-size: 0.9rem; }
    th { font-family: var(--font-display); font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); }
    .tag { display: inline-block; font-size: 0.65rem; padding: 0.15rem 0.5rem; border: 1px solid var(--gold-dim); border-radius: 2px; color: var(--gold); text-transform: uppercase; letter-spacing: 0.08em; }
    .error { background: rgba(139,26,26,0.2); border: 1px solid var(--crimson); color: #e07070; padding: 0.7rem 1rem; border-radius: 2px; margin-bottom: 1rem; font-size: 0.9rem; }
    .success { background: rgba(201,168,76,0.1); border: 1px solid var(--gold-dim); color: var(--gold); padding: 0.7rem 1rem; border-radius: 2px; margin-bottom: 1rem; font-size: 0.9rem; }
    .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem; }
    .stat-box { background: var(--navy); border: 1px solid rgba(201,168,76,0.15); padding: 1.25rem; text-align: center; }
    .stat-num { font-family: var(--font-display); font-size: 2rem; color: var(--gold); }
    .stat-label { font-size: 0.75rem; color: var(--parchment-dim); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 0.3rem; }
  </style>
</head>
<body>
  <% if (typeof admin !== 'undefined' && admin) { %>
  <div class="topbar">
    <span class="brand">♛ FestFlow Admin</span>
    <div class="topnav">
      <a href="/admin/dashboard">Dashboard</a>
      <a href="/admin/fests/new">New Fest</a>
      <a href="/admin/events/new">New Event</a>
      <a href="/admin/logout">Logout</a>
    </div>
  </div>
  <% } %>
  <div class="wrap">
    <%- body %>
  </div>
</body>
</html>